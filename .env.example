PORT=3000
NODE_ENV=development

APP_NAME=chat-auth-service
CLIENT_ORIGIN=http://localhost:5173

JWT_SECRET=change-this-secret-to-a-long-random-value
JWT_EXPIRES_IN=1d

DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chat_auth
DB_USER=app_user
DB_PASSWORD=app_password
DB_LOGGING=false
DB_SYNC=true
